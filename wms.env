# ══════════════════════════════════════════
# APPLICATION
# ══════════════════════════════════════════
NODE_ENV=production
PORT=3000
API_PREFIX=/v1
APP_NAME=WMS-API
APP_VERSION=2.4.0

# ══════════════════════════════════════════
# CORS — Giới hạn domain truy cập
# ══════════════════════════════════════════
CORS_ORIGIN=https://wms.yourdomain.com,https://admin.wms.yourdomain.com
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_CREDENTIALS=true

# Database
DB_PASS=StrongPass123!
REDIS_PASS=RedisPass123!

# JWT
JWT_SECRET=wms-super-secret-jwt-key-must-be-at-least-32-characters-long-2025!

# ERP (pick one)
ERP_PROVIDER=None       # None | Sap | Odoo

# SAP
SAP_HOST=
SAP_USER=
SAP_PASS=

# Odoo
ODOO_URL=
ODOO_DB=
ODOO_USER=
ODOO_API_KEY=


# Google OAuth
Google__ClientId=123456789-xxxxx.apps.googleusercontent.com
Google__ClientSecret=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
Google__RedirectUri=https://api.wms.vn/v1/auth/google/callback
Google__FrontendCallbackUrl=https://wms.vn/auth/callback

# Facebook OAuth
Facebook__AppId=123456789012345
Facebook__AppSecret=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
Facebook__RedirectUri=https://api.wms.vn/v1/auth/facebook/callback
Facebook__FrontendCallbackUrl=https://wms.vn/auth/callback

# X (Twitter) OAuth 2.0
X__ClientId=YourOAuth2ClientId
X__ClientSecret=YourOAuth2ClientSecret
X__RedirectUri=https://api.wms.vn/v1/auth/x/callback
X__FrontendCallbackUrl=https://wms.vn/auth/callback

# Microsoft Identity Platform
Microsoft__ClientId=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
Microsoft__ClientSecret=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
Microsoft__Tenant=common
Microsoft__RedirectUri=https://api.wms.vn/v1/auth/microsoft/callback
Microsoft__FrontendCallbackUrl=https://wms.vn/auth/callback

# LinkedIn OAuth 2.0
LinkedIn__ClientId=86xxxxxxxxxx
LinkedIn__ClientSecret=xxxxxxxxxxxxxxxx
LinkedIn__RedirectUri=https://api.wms.vn/v1/auth/linkedin/callback
LinkedIn__FrontendCallbackUrl=https://wms.vn/auth/callback
