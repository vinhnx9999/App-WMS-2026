@inherits LayoutComponentBase
@implements IDisposable
@inject DP.AppWMS.Web.Services.State.LayoutService LayoutService

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="@_theme"/>
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="min-h-screen @(_isDarkMode ? "dark bg-gray-950 text-gray-50" : "bg-gray-50 text-gray-900")">
    <MudLayout>
        <TopNavbar IsDarkMode="@_isDarkMode" OnToggleNotifications="ToggleNotifications" />
      
        <MudMainContent Class="pt-16">
            <main class="p-4">
                @Body
            </main>
        </MudMainContent>
    </MudLayout>
</div>

@code {
    private bool _isDarkMode = false;
    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#594AE2",         
            AppbarBackground = "#ffffff",
            AppbarText = "#1f2937",      
            Background = "#f9fafb",      
            TextPrimary = "#111827",      
            TextSecondary = "#4b5563"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#ab9eff",          
            AppbarBackground = "#111827", 
            AppbarText = "#f9fafb",    
            Background = "#030712",       
            TextPrimary = "#f9fafb",
            TextSecondary = "#9ca3af"
        }
    };
    private bool isNotificationOpen = false;

    protected override void OnInitialized()
    {
        _isDarkMode = LayoutService.IsDarkMode;
        LayoutService.OnThemeChanged += HandleThemeChanged;
    }

    private void HandleThemeChanged()
    {
        _isDarkMode = LayoutService.IsDarkMode;
        StateHasChanged();
    }

    private void ToggleNotifications()
    {
        isNotificationOpen = !isNotificationOpen;
    }

    public void Dispose()
    {
        LayoutService.OnThemeChanged -= HandleThemeChanged;
    }
}